use flake
# Prefer venv Python for HERMES_REAL_BIN (scripts/core/hermes runs `python -m hermes_cli.main`).
# Do NOT run `command -v hermes` before PATH_add — that grabs a global install.
if [[ -x "${PWD}/venv/bin/python" ]]; then
  export HERMES_REAL_BIN="${PWD}/venv/bin/python"
elif [[ -x "${PWD}/venv/bin/hermes" ]]; then
  export HERMES_REAL_BIN="${PWD}/venv/bin/hermes"
else
  export HERMES_REAL_BIN="$(command -v hermes)"
fi
PATH_add scripts/core
PATH_add scripts/shell
# Bare `droplet` / `droplet_direct` on PATH → SSH as hermesuser (see scripts/shell/droplet).
# VPS Hermes hop: trailing droplet only — e.g. hermes doctor droplet (hermes_cli.main + agent-droplet).
# Optional: source scripts/shell/hermes-env.sh from ~/.zshrc for hermes()/droplet() overrides outside this repo.
