use flake

# VPS / droplet: zero-argument CLI proxies (hermes-droplet, hermes-tui-droplet, …).
# Requires ~/.env/.env with SSH_* and SSH_SUDO_PASSWORD (same as scripts/ssh_droplet.sh).
# Opt out: export AGENT_DROPLET_DISABLE=1 before `direnv allow`, or remove this block.
if [[ -f "${HOME}/.env/.env" && "${AGENT_DROPLET_DISABLE:-}" != "1" ]]; then
  export AGENT_DROPLET_ENABLE=1
  source "${PWD}/scripts/source_droplet_agent_cli.sh"
fi
