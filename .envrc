use flake
# Prefer this repo's venv for HERMES_REAL_BIN. Do NOT run `command -v hermes` before PATH_add:
# that resolves a global pipx/brew hermes instead of ./venv/bin/hermes.
if [[ -x "${PWD}/venv/bin/hermes" ]]; then
  export HERMES_REAL_BIN="${PWD}/venv/bin/hermes"
else
  export HERMES_REAL_BIN="$(command -v hermes)"
fi
PATH_add scripts
