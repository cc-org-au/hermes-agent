<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>org.hermes.tailscale-ssh-listen-refresh</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/libexec/hermes/operator_mini_refresh_tailscale_listenaddress.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>StandardErrorPath</key>
  <string>/var/log/hermes-tailscale-ssh-refresh.log</string>

  <key>StandardOutPath</key>
  <string>/var/log/hermes-tailscale-ssh-refresh.log</string>
</dict>
</plist>

