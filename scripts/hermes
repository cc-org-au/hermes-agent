#!/usr/bin/env bash
# If the last argument is "droplet", run the same CLI on the VPS (see scripts/agent-droplet).
# Otherwise run the repo venv's `hermes` when present (see .envrc); else HERMES_REAL_BIN.
set -euo pipefail
_root="$(cd "$(dirname "$0")" && pwd)"
_repo="$(cd "$_root/.." && pwd)"
_venv_hermes="$_repo/venv/bin/hermes"
_last=
for _last in "$@"; do :; done
if [[ $# -ge 1 && "$_last" == "droplet" ]]; then
  if [[ $# -eq 1 ]]; then
    exec "$_root/agent-droplet"
  fi
  set -- "${@:1:$(($# - 1))}"
  exec "$_root/agent-droplet" "$@"
fi
if [[ -x "$_venv_hermes" ]]; then
  _real="$_venv_hermes"
elif [[ -n "${HERMES_REAL_BIN:-}" ]]; then
  _real="${HERMES_REAL_BIN}"
else
  echo "hermes: no venv at ${_venv_hermes} and HERMES_REAL_BIN is unset. Create the venv (see README) or set HERMES_REAL_BIN." >&2
  exit 127
fi
if [[ "$_real" == "$_root/hermes" ]]; then
  echo "hermes: HERMES_REAL_BIN points at this wrapper; fix .envrc (see comment about venv vs command -v)." >&2
  exit 1
fi
exec "$_real" "$@"
